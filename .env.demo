# ============================================================================
# FeatureGen — FULL END-TO-END DEMO environment  (NOT for production)
# ----------------------------------------------------------------------------
# Turns ON every governed pass so a single upload exercises the whole
# evidence-authority pipeline: advisory enrichment -> Pass C join discovery ->
# Pass B grain/availability synth -> governed proposals -> human confirm ->
# operational graph + governance dashboard.
#
# The app does NOT auto-load this file. Use the launcher:   ./run-demo.sh
# or source it yourself:   set -a && source .env.demo && set +a && make api
# ============================================================================

# ---- Required: your local Postgres (the event store) -----------------------
FEATUREGEN_DSN=postgresql://localhost:5432/featuregen
FEATUREGEN_AUDIT_HMAC_KEY=demo-only-not-a-real-secret-change-me
# Apply pending migrations on API startup (dev/demo convenience; deliberate step in prod).
FEATUREGEN_AUTO_MIGRATE=1

# ---- Dev auth stub: routes read X-User / X-Roles headers -------------------
# The React session bar sends these; the dual-admin join confirm needs TWO
# DISTINCT subjects, each carrying the platform-admin role.
FEATUREGEN_AUTH_STUB=1

# ---- LLM provider ----------------------------------------------------------
# Powers advisory enrichment (concept / definition / domain) AND Pass B.
# Pass B (grain/availability) ONLY runs when a client is configured, so the
# full demo REQUIRES a working key here. Without it: uploads still ingest and
# Pass C still runs, but columns stay un-enriched and Pass B is skipped.
FEATUREGEN_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# Default model for all LLM calls (enrichment + Pass B). Override here if needed.
FEATUREGEN_LLM_MODEL=claude-sonnet-5

# ============================================================================
# GOVERNED PASSES — all ON
# ============================================================================
# Pass C: deterministic single-column join DISCOVERY. This ALREADY implies governed-join routing
# (graph.governed_joins_enabled() is true when OVERLAY_PASS_C=1), so OVERLAY_GOVERNED_JOINS is NOT
# set here — it would be redundant. Set OVERLAY_GOVERNED_JOINS=1 alone (without Pass C) only if you
# want declared CSV joins governed but automatic Pass C discovery OFF.
OVERLAY_PASS_C=1
# Pass B: LLM-proposed grain / availability_time (needs the LLM client above).
OVERLAY_TABLE_SYNTH=1

# ---- Batched enrichment: deliberately LEFT IN SINGLE MODE ------------------
# Batching is an internal COST optimization gated by a gold-set eval against a
# live provider — not a demo-visible feature, and unproven batching can degrade
# enrichment mid-demo. Leave off for a clean demo. To also batch, uncomment:
# OVERLAY_ENRICH_CONCEPT_MODE=batch
# OVERLAY_ENRICH_DEFINITION_MODE=batch
# OVERLAY_ENRICH_DOMAIN_MODE=batch
# NOTE: OVERLAY_ENRICH_TABLE_SYNTH_MODE is a DEAD setting — Pass B synthesis is batch-only and never
# consults it (see table_synth.py). OVERLAY_TABLE_SYNTH=1 above is Pass B's only real gate.
