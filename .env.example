# Copy to .env and adjust. Loaded by featuregen.config (and read by the test harness).

# Runtime database (the event store, outbox, timers, projections, etc.).
FEATUREGEN_DSN=postgresql://localhost:5432/featuregen

# Test database. If set, the test suite uses this server; if unset, it spins up an
# ephemeral PostgreSQL cluster via pytest-postgresql.
FEATUREGEN_TEST_DSN=postgresql://localhost:5432/featuregen_test
