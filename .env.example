# Copy to .env and adjust. NOTE: the app does NOT auto-load this file — featuregen.config and the
# flag gates read os.environ directly, and `make api` does not source it. Export these into the
# environment before launching, e.g.  set -a && source .env && set +a && make api  (the demo
# launcher ./run-demo.sh does exactly this for .env.demo). The test harness reads the variables.

# Runtime database (the event store, outbox, timers, projections, etc.).
FEATUREGEN_DSN=postgresql://localhost:5432/featuregen

# MIGRATIONS: the schema is NOT auto-applied by default. After pulling code that adds a migration,
# run `python -m featuregen migrate` — otherwise endpoints touching the new schema return 500 and the
# API logs "DATABASE SCHEMA IS BEHIND THE CODE" at startup. Set FEATUREGEN_AUTO_MIGRATE=1 to have the
# API auto-apply pending migrations on startup (convenient for dev/demo; keep it a deliberate step in
# production).
# FEATUREGEN_AUTO_MIGRATE=1

# Test database. If set, the test suite uses this server; if unset, it spins up an
# ephemeral PostgreSQL cluster via pytest-postgresql.
FEATUREGEN_TEST_DSN=postgresql://localhost:5432/featuregen_test

# Verifier-held HMAC key for the tamper-evident security-audit chain (§6.2). REQUIRED in
# production: security.audit fails closed and refuses to sign the chain if this is unset
# (a keyless hash would be forgeable by any writer). Keep it out of the database; rotate via
# your secrets manager. The test harness sets a deterministic key automatically.
FEATUREGEN_AUDIT_HMAC_KEY=change-me-to-a-high-entropy-secret

# ── LLM provider (optional) ────────────────────────────────────────────────────────────────────
# Wires the config-gated Claude adapter. Unset: uploads ingest UN-enriched (no concept/definition/
# domain), Pass B is skipped, and feature-assist endpoints return 503 — no fake AI (Decision D5).
# FEATUREGEN_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# Default model for every LLM call (enrichment + Pass B); overridable per deployment. Default sonnet.
# FEATUREGEN_LLM_MODEL=claude-sonnet-5
# FEATUREGEN_LLM_MAX_TOKENS=4096   FEATUREGEN_LLM_THINKING=adaptive   FEATUREGEN_LLM_EFFORT=high

# ── Governed passes (all default OFF; the base upload→graph→evidence path is always on) ──────────
# Pass C — deterministic single-column join DISCOVERY. Implies governed-join routing on its own, so
# you do NOT also need OVERLAY_GOVERNED_JOINS. Proposals require two DISTINCT platform-admins to VERIFY.
# OVERLAY_PASS_C=1
# Governed-join routing for DECLARED CSV joins WITHOUT Pass C discovery (redundant if Pass C is on).
# OVERLAY_GOVERNED_JOINS=1
# Pass B — LLM-proposed table grain / availability_time (single-confirmer). Needs the LLM provider above.
# OVERLAY_TABLE_SYNTH=1
# Dev auth stub: routes read X-User / X-Roles headers instead of a real session.
# FEATUREGEN_AUTH_STUB=1
# 3B.3c kill-switch: set to 1 to have the shadow planner also COMPILE binding contracts (log-only; default off).
# FEATUREGEN_INTENT_CONTRACT_COMPILE=1
# 3B.4 shadow telemetry: set to 1 to PERSIST the shadow planner's classifications (manifest + run +
# plan tables, WORM) for the 3C-enablement gate. Independent of the compile flag; default off (no writes).
# FEATUREGEN_INTENT_SHADOW_TELEMETRY=1
# 3B.4 gate signature: the TRUSTED PUBLIC key (PEM) verifiers/CI use to check the 3C-enablement-gate
# artifact's ed25519 DETACHED signature. The PRIVATE half is held by a separate signing authority, NOT
# here. Fail-closed: verification refuses when unset. (Public key — safe to distribute, never the private.)
# FEATUREGEN_INTENT_GATE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# 3C.1 gate operationalization: the producing code version stamped on each shadow run (the cohort a
# gate window selects over). Set at deploy, e.g. the git SHA. Unset -> "unset" (uncertified, excluded).
# FEATUREGEN_PRODUCER_COMMIT=<git-sha>
# Frontend: enable the internal gate-evaluation admin console (platform-admin only).
# VITE_INTENT_GATE_CONSOLE=1
